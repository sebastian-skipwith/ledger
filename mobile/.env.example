# Copy to .env. EXPO_PUBLIC_* vars are inlined at build time (not secret).
EXPO_PUBLIC_API_URL=https://ledger-production-5649.up.railway.app
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Product analytics (PostHog) — project API key (phc_...) + region host.
# Behavior events only; the app never sends financial data/PII. No-ops if unset.
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Crash/error monitoring (Sentry) — the React Native project DSN. No-ops if unset.
EXPO_PUBLIC_SENTRY_DSN=
