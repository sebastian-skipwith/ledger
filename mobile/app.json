{
  "expo": {
    "name": "Persistence",
    "slug": "persistence",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "persistence",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0a0a0f",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "finance.persistence.app"
    },
    "android": {
      "package": "finance.persistence.app",
      "adaptiveIcon": {
        "backgroundColor": "#0a0a0f",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ],
      "versionCode": 2
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "@react-native-google-signin/google-signin",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Use Face ID to unlock Persistence."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0a0a0f",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "NetWorth",
              "label": "Net Worth",
              "minWidth": "180dp",
              "minHeight": "110dp",
              "targetCellWidth": 3,
              "targetCellHeight": 2,
              "description": "Your net worth and safe-to-spend at a glance",
              "previewImage": "./assets/images/icon.png",
              "updatePeriodMillis": 1800000,
              "resizeMode": "horizontal|vertical",
              "widgetFeatures": "reconfigurable"
            }
          ]
        }
      ],
      "@sentry/react-native",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "958389de-70ce-4b24-a2e4-96f145aba4e9"
      }
    },
    "owner": "sskipwit"
  }
}
